# Server
PORT=4000
# Comma-separated list of allowed origins (the Cloudflare site + localhost dev)
CORS_ORIGINS=http://localhost:5173,https://pokecop.com

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Database
MONGODB_URI=mongodb://localhost:27017/pokecop-blog

# Cloudflare Deploy Hook (created in Cloudflare dashboard; leave blank to disable)
CLOUDFLARE_DEPLOY_HOOK_URL=

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
